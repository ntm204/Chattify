PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://root:rootpassword@localhost:5432/chatiffy?schema=public"
MONGODB_URI="mongodb://root:rootpassword@localhost:27017/chatiffy?authSource=admin"

# Redis
REDIS_URL="redis://:rootpassword@localhost:6379"

# JWT
JWT_SECRET="CHANGE_ME"
JWT_2FA_SECRET="CHANGE_ME"

# 2FA
TWO_FACTOR_ENCRYPTION_KEY="CHANGE_ME"
TWO_FACTOR_SALT="CHANGE_ME"

# SMTP
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER="user"
SMTP_PASS="pass"
FORCE_SEND_MAIL=false

# SMS
TWILIO_ACCOUNT_SID="sid"
TWILIO_AUTH_TOKEN="token"
TWILIO_PHONE_NUMBER="+1"

# Others
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
RUN_AUTH_INTEGRATION_E2E=false
